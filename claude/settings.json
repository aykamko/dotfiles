{
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh 'Claude Code' 'Claude is done and waiting for input'"
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh 'Claude Code' 'Claude needs permission to continue'"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh 'Claude Code' 'Claude has a question for you'"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh 'Claude Code' 'Claude needs your attention'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "figma-security-guidance@figma-internal": true,
    "figma-plugin@figma-internal": true,
    "fix-a11y@figma-internal": true,
    "fpl-practices@figma-internal": true,
    "validate-and-fix@figma-internal": true,
    "feature-flag-cleanup@figma-internal": true,
    "qawolf-from-e2e@figma-internal": true,
    "ml-tools@figma-internal": true,
    "send-to-github@figma-internal": true,
    "prodsec@figma-internal": true,
    "testing@figma-internal": true,
    "ci-tools@figma-internal": true,
    "coder-tools@figma-internal": true,
    "update-dependency@figma-internal": true
  },
  "editorMode": "vim",
  "viMode": true
}
