###############################################################################
# Platform Specific
###############################################################################
if [[ $(uname -s) == "Darwin" ]]; then
  # alias for rm (requires trash script)
  if (( $+commands[trash] )); then
      alias rm=trash
  fi

  # copy to mac osx clipboard
  copy() { cat $1 | pbcopy }

  # clean .DS_Store
  dsclean() { find . -name ".DS_Store" -exec /bin/rm -rf {} \; }

  # docker+tmux
  docker-mount() {
      eval "$(docker-machine env default)"
      tmux setenv DOCKER_TLS_VERIFY $DOCKER_TLS_VERIFY
      tmux setenv DOCKER_HOST $DOCKER_HOST
      tmux setenv DOCKER_CERT_PATH $DOCKER_CERT_PATH
      tmux setenv DOCKER_MACHINE_NAME $DOCKER_MACHINE_NAME
  }

  __git_statusline() {
    local reset='%f%b'
    local light_blue='%F{cyan}'
    local yellow='%F{yellow}'
    local git_display=""
    local branch
    branch=$(git --no-optional-locks branch --show-current 2>/dev/null)
    if [[ -n "$branch" ]]; then
      git_display="${light_blue}(${reset}${yellow}${branch}${reset}${light_blue})${reset}"
    fi
    echo "${git_display}"
  }

  setopt PROMPT_SUBST
  export PS1='%F{200}macbook%f%b %F{blue}%~%f $(__git_statusline) %F{green}%#%f '
fi


