# vim: set ft=zsh:

# Shell options
unsetopt CORRECT         # disable autocorrect suggestions for commands
unsetopt AUTO_NAME_DIRS  # don't resolve environment variables in prompt
setopt NO_NOMATCH        # pass bad match to command
setopt IGNORE_EOF        # disable ctrl-d to logout
setopt clobber           # don't warn when overwriting existing file

# Vi mode — must precede other bindkey calls so they go into the vi keymap
bindkey -v

# Base key bindings
bindkey -r '^D'
bindkey '^A' beginning-of-line
bindkey '^E' end-of-line
autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^G' edit-command-line

# Auto-source topical scripts
if [[ -d $DOTFILES/zsh/scripts ]]; then
  for f in $DOTFILES/zsh/scripts/*.zsh; do
    source $f
  done
fi

# Local override (must be last)
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
